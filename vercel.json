{
  "rewrites": [
    { "source": "/skill", "destination": "/skill.html" },
    { "source": "/protocol", "destination": "/protocol.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" }
  ]
}

{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*.html"
    }
  ]
}
